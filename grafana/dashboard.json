{
  "__inputs": [
    {
      "name": "DS_TIMESCALEDB",
      "label": "TimescaleDB",
      "description": "PostgreSQL data source connected to your TimescaleDB instance",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-postgresql-datasource",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],
  "id": null,
  "uid": "timescaledb-exporter",
  "title": "Home Assistant — TimescaleDB Exporter",
  "description": "Monitor state history, numeric trends, state change rates, and database health for the TimescaleDB Exporter integration.",
  "tags": ["home-assistant", "timescaledb"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "grafana-postgresql-datasource",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "grafana-postgresql-datasource",
          "uid": "${datasource}"
        },
        "definition": "SELECT entity_id FROM ha_entity_metadata ORDER BY entity_id",
        "hide": 0,
        "includeAll": false,
        "label": "Entity",
        "multi": false,
        "name": "entity_id",
        "options": [],
        "query": "SELECT entity_id FROM ha_entity_metadata ORDER BY entity_id",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Database Size",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 10737418240 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT pg_database_size(current_database()) AS size;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tracked Entities",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) AS entities FROM ha_entity_metadata;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Compression Ratio",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT CASE WHEN SUM(before_compression_total_bytes) > 0 THEN 1.0 - (SUM(after_compression_total_bytes)::float / SUM(before_compression_total_bytes)::float) ELSE 0 END AS ratio FROM timescaledb_information.compressed_chunk_stats WHERE hypertable_name = 'ha_states';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total State Changes (24h)",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) AS changes FROM ha_states WHERE time > NOW() - INTERVAL '24 hours';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entity History",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Entity State History — $entity_id",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "pointSize": 3,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT time AS \"time\", state_numeric AS \"value\" FROM ha_states WHERE entity_id = '$entity_id' AND state_numeric IS NOT NULL AND $__timeFilter(time) ORDER BY time;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Numeric Trends",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Hourly Aggregates — $entity_id",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 5,
            "pointSize": 3,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "min_value" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "max_value" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "avg_value" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT bucket AS \"time\", avg_value, min_value, max_value FROM ha_states_hourly WHERE entity_id = '$entity_id' AND $__timeFilter(bucket) ORDER BY bucket;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Activity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "State Change Rate (events/hour)",
      "type": "barchart",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "fillOpacity": 80,
            "gradientMode": "none",
            "showValue": "auto",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "orientation": "auto",
        "barWidth": 0.8,
        "groupWidth": 0.7
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT bucket AS \"time\", SUM(state_change_count) AS \"changes\" FROM ha_state_changes_hourly WHERE $__timeFilter(bucket) GROUP BY bucket ORDER BY bucket;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 20 Entities by Activity (24h)",
      "type": "table",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "changes" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "changes", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT entity_id, COUNT(*) AS changes FROM ha_states WHERE time > NOW() - INTERVAL '24 hours' GROUP BY entity_id ORDER BY changes DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Database Internals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "title": "Chunk Overview",
      "type": "table",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${datasource}"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "is_compressed" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "true": { "text": "Yes", "color": "green" }, "false": { "text": "No", "color": "orange" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "range_start", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "rawSql": "SELECT hypertable_name, chunk_name, range_start, range_end, is_compressed FROM timescaledb_information.chunks WHERE hypertable_schema = 'public' ORDER BY range_start DESC LIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
